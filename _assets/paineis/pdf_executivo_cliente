  .red-zone ol { list-style: none; counter-reset: r; }
  .red-zone li {
    counter-increment: r;
    font-family: 'Inter', sans-serif; font-size: 9pt; line-height: 1.45;
    padding: 2mm 0; border-bottom: 0.2mm dashed rgba(245,239,230,.25);
    display: flex; gap: 4mm;
