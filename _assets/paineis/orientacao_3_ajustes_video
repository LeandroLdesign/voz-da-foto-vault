<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<title>3 ajustes pros próximos vídeos — A Voz da Foto</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html, body { background: #F5EFE6; font-family: 'Inter', sans-serif; color: #282D29; }

  @page {
    size: A4 portrait;
    margin: 0;
  }

  /* Página A4 retrato em mm. Usar mm garante que o Chrome respeite o tamanho real */
  .page {
    width: 210mm;
    height: 297mm;
    background: #F5EFE6;
    position: relative;
    overflow: hidden;
    padding: 22mm 22mm 32mm;
    page-break-after: always;
    page-break-inside: avoid;
  }
  .page:last-child { page-break-after: auto; }

  /* textura editorial sutil */
  .page::before {
    content: '';
    position: absolute; inset: 0;
    background-image:
      radial-gradient(circle at 18% 12%, rgba(185,76,20,.05) 0, transparent 45%),
      radial-gradient(circle at 88% 88%, rgba(198,134,67,.06) 0, transparent 45%);
    pointer-events: none;
  }

  /* cantos viewfinder */
  .viewfinder { position: absolute; width: 8mm; height: 8mm; border: 0.6mm solid #B94C14; z-index: 3; }
  .vf-tl { top: 9mm; left: 9mm; border-right: none; border-bottom: none; }
  .vf-tr { top: 9mm; right: 9mm; border-left: none; border-bottom: none; }
  .vf-bl { bottom: 9mm; left: 9mm; border-right: none; border-top: none; }
  .vf-br { bottom: 9mm; right: 9mm; border-left: none; border-top: none; }

  /* header geral */
  .header {
    display: flex; justify-content: space-between; align-items: baseline;
    margin-bottom: 10mm; position: relative; z-index: 2;
    padding-bottom: 4mm; border-bottom: 0.25mm solid rgba(40,45,41,.18);
  }
  .brand { font-family: 'Cormorant Garamond', serif; font-style: italic; font-weight: 500; font-size: 13pt; color: #B94C14; letter-spacing: .3px; }
  .meta { font-family: 'Inter', sans-serif; font-weight: 500; font-size: 7pt; color: #282D29; opacity: .55; letter-spacing: 1.5px; text-transform: uppercase; }

  /* footer geral */
  .footer {
    position: absolute; bottom: 10mm; left: 22mm; right: 22mm;
    display: flex; justify-content: space-between; align-items: flex-end;
    z-index: 5; padding-top: 4mm; border-top: 0.25mm solid rgba(40,45,41,.18);
    background: #F5EFE6;
  }
  .footer-left { font-family: 'Inter', sans-serif; font-size: 6.5pt; color: #282D29; opacity: .55; letter-spacing: 1.2px; text-transform: uppercase; font-weight: 500; }
  .stamp { font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 11pt; color: #B94C14; opacity: .8; }
  .pagenum { font-family: 'Cormorant Garamond', serif; font-weight: 500; font-size: 10pt; color: #282D29; opacity: .55; }

  /* ===== CAPA ===== */
  .capa { display: flex; flex-direction: column; }
  .capa .eyebrow {
    font-family: 'Inter', sans-serif; font-weight: 600; font-size: 8pt;
    color: #B94C14; letter-spacing: 3px; text-transform: uppercase;
    margin-bottom: 6mm; position: relative; z-index: 2;
  }
  .capa h1 {
    font-family: 'Cormorant Garamond', serif; font-weight: 500;
    font-size: 64pt; line-height: .92; letter-spacing: -1.5px;
    color: #282D29; margin-bottom: 7mm; position: relative; z-index: 2;
  }
  .capa h1 em { font-style: italic; color: #B94C14; font-weight: 500; }
  .capa .lede {
    font-family: 'Cormorant Garamond', serif; font-style: italic;
    font-size: 15pt; font-weight: 400; color: #282D29; opacity: .7;
    margin-bottom: 16mm; max-width: 145mm; line-height: 1.35;
    position: relative; z-index: 2;
  }
  .capa .indice {
    background: rgba(254,254,254,.6); border-left: 1mm solid #B94C14;
    padding: 8mm 10mm; max-width: 130mm; position: relative; z-index: 2;
  }
  .capa .indice-titulo {
    font-family: 'Inter', sans-serif; font-weight: 600; font-size: 7pt;
    color: #282D29; opacity: .55; letter-spacing: 2.5px; text-transform: uppercase;
    margin-bottom: 4mm;
  }
  .capa .indice ol { list-style: none; counter-reset: cap; }
  .capa .indice li {
    counter-increment: cap;
    font-family: 'Cormorant Garamond', serif; font-size: 14pt; font-weight: 500;
    color: #282D29; padding: 2mm 0; display: flex; align-items: baseline; gap: 4mm;
    border-bottom: 0.2mm dashed rgba(40,45,41,.18);
  }
  .capa .indice li:last-child { border-bottom: none; }
  .capa .indice li::before {
    content: counter(cap, decimal-leading-zero);
    font-family: 'Cormorant Garamond', serif; font-style: italic;
    color: #C68643; font-weight: 600; font-size: 12pt; min-width: 9mm;
  }
  .capa .indice li em { font-style: italic; color: #B94C14; }
  .capa .indice li .pg {
    margin-left: auto; font-family: 'Inter', sans-serif;
    font-size: 7pt; color: #282D29; opacity: .5; letter-spacing: 1.5px; font-weight: 500;
  }
  .capa .autor {
    margin-top: 14mm; font-family: 'Inter', sans-serif; font-size: 8pt;
    color: #282D29; opacity: .7; letter-spacing: 1px; line-height: 1.7;
    position: relative; z-index: 2;
  }
  .capa .autor strong { font-weight: 600; color: #B94C14; }

  /* ===== PÁGINAS DE CONTEÚDO ===== */
  .num-grande {
    font-family: 'Cormorant Garamond', serif; font-weight: 500;
    font-size: 72pt; color: #C68643; opacity: .35;
    line-height: 1; letter-spacing: -3px; margin-bottom: -6mm;
    position: relative; z-index: 2;
  }
  .ajuste-eyebrow {
    font-family: 'Inter', sans-serif; font-weight: 600; font-size: 7pt;
    color: #B94C14; letter-spacing: 2.5px; text-transform: uppercase;
    margin-bottom: 3mm; position: relative; z-index: 2;
  }
  .ajuste-titulo {
    font-family: 'Cormorant Garamond', serif; font-weight: 500;
    font-size: 32pt; line-height: 1; letter-spacing: -1px;
    color: #282D29; margin-bottom: 3mm; position: relative; z-index: 2;
  }
  .ajuste-titulo em { font-style: italic; color: #B94C14; font-weight: 500; }
  .ajuste-sub {
    font-family: 'Cormorant Garamond', serif; font-style: italic;
    font-size: 11pt; color: #282D29; opacity: .65; margin-bottom: 6mm;
    position: relative; z-index: 2; line-height: 1.4;
  }

  /* corpo */
  .corpo p {
    font-family: 'Inter', sans-serif; font-size: 9.5pt; line-height: 1.55;
    color: #282D29; margin-bottom: 3.5mm; position: relative; z-index: 2;
  }
  .corpo p strong { font-weight: 600; color: #B94C14; }
  .corpo .destaque {
    font-family: 'Cormorant Garamond', serif; font-style: italic;
    font-size: 13pt; font-weight: 500; color: #282D29;
    border-left: 0.8mm solid #B94C14; padding: 1mm 0 1mm 5mm;
    margin: 5mm 0 5mm; line-height: 1.35;
  }

  /* checklist */
  .check {
    background: #FEFEFE; border: 0.25mm solid rgba(40,45,41,.12);
    padding: 4mm 6mm; margin-top: 4mm; position: relative; z-index: 2;
  }
  .check-titulo {
    font-family: 'Cormorant Garamond', serif; font-style: italic;
    font-weight: 600; font-size: 10pt; color: #B94C14;
    margin-bottom: 2mm; letter-spacing: .3px;
  }
  .check ul { list-style: none; }
  .check li {
    font-family: 'Inter', sans-serif; font-size: 8pt; line-height: 1.45;
    padding: 1mm 0; color: #282D29; display: flex; gap: 3mm;
    border-bottom: 0.2mm solid rgba(40,45,41,.08);
  }
  .check li:last-child { border-bottom: none; }
  .check li::before {
    content: '✓'; color: #B94C14; font-weight: 700; font-size: 10pt;
    min-width: 4mm; line-height: 1.4;
  }
  .check li.no::before { content: '✕'; color: #C68643; opacity: .75; }
  .check li strong { font-weight: 600; color: #282D29; }

  /* esquema visual SVG */
  .esquema {
    margin: 4mm 0; background: #FEFEFE;
    border: 0.25mm solid rgba(40,45,41,.12);
    padding: 5mm; position: relative; z-index: 2;
    text-align: center;
  }
  .esquema-titulo {
    font-family: 'Inter', sans-serif; font-weight: 600; font-size: 6.5pt;
    color: #B94C14; letter-spacing: 2px; text-transform: uppercase;
    margin-bottom: 4mm;
  }
  .esquema-legenda {
    font-family: 'Cormorant Garamond', serif; font-style: italic;
    font-size: 9pt; color: #282D29; opacity: .7; margin-top: 4mm;
  }
  svg { width: 100%; max-width: 130mm; height: auto; display: block; margin: 0 auto; }

  /* página final */
  .final h1 {
    font-family: 'Cormorant Garamond', serif; font-weight: 500;
    font-size: 42pt; line-height: 1; letter-spacing: -1px;
    color: #282D29; margin-bottom: 5mm; position: relative; z-index: 2;
  }
  .final h1 em { font-style: italic; color: #B94C14; }
  .final .resumo {
    margin-top: 8mm; display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 4mm; position: relative; z-index: 2;
  }
  .final .card {
    background: #FEFEFE; border-top: 1mm solid #B94C14;
    padding: 6mm 5mm; min-height: 50mm;
  }
  .final .card .n {
    font-family: 'Cormorant Garamond', serif; font-style: italic;
    font-size: 24pt; color: #C68643; font-weight: 600; line-height: 1;
    margin-bottom: 3mm;
  }
  .final .card h3 {
    font-family: 'Cormorant Garamond', serif; font-size: 14pt; font-weight: 600;
    color: #282D29; line-height: 1.1; margin-bottom: 2.5mm;
  }
  .final .card h3 em { font-style: italic; color: #B94C14; }
  .final .card p {
    font-family: 'Inter', sans-serif; font-size: 8pt; line-height: 1.5;
    color: #282D29; opacity: .85;
  }
  .final .assinatura {
    margin-top: 8mm; padding: 7mm 8mm;
    background: #282D29; color: #F5EFE6; position: relative; z-index: 2;
  }
  .final .assinatura-label {
    font-family: 'Inter', sans-serif; font-weight: 600; font-size: 7pt;
    color: #C68643; letter-spacing: 2.5px; text-transform: uppercase; margin-bottom: 3mm;
  }
  .final .assinatura p {
    font-family: 'Cormorant Garamond', serif; font-size: 12pt;
    line-height: 1.45; font-weight: 400;
  }
  .final .assinatura p em { font-style: italic; color: #C68643; }
</style>
</head>
